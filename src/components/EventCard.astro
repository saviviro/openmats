---
import type { CollectionEntry } from "astro:content";

import {
  formatEventDate,
  formatEventTime,
  formatVerifiedDate,
  getEventPriceCategory,
  getEventFormatStates,
  keepEuroAmountTogether,
} from "../lib/events";
import { getEventTranslation, intlLocale, ui, type Locale } from "../lib/i18n";

interface Props {
  event: CollectionEntry<"events">;
  locale: Locale;
}

const { event, locale } = Astro.props;
const { data } = event;
const copy = ui[locale];
const address = `${data.venue.streetAddress}, ${data.venue.postalCode} ${data.venue.city}`;
const mapUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
const formatLabels = { gi: "Gi", "no-gi": "No-gi" } as const;
const formatStateLabels = {
  available: copy.available,
  unavailable: copy.unavailable,
  unknown: copy.unknownFormat,
} as const;
const formatStateIcons = {
  available: "✓",
  unavailable: "×",
  unknown: "?",
} as const;
const formatStates = getEventFormatStates(data.formats);
const priceCategory = getEventPriceCategory(data.price.amount);
const eventText = getEventTranslation(locale, data.schedule.seriesId, {
  priceNote: data.price.note,
  accessDescription: data.access.description,
  exceptionNote: data.schedule.exceptionNote,
});
const priceNote = keepEuroAmountTogether(eventText.priceNote);
const statusLabel = {
  scheduled: null,
  cancelled: copy.cancelled,
  rescheduled: copy.rescheduled,
  uncertain: null,
}[data.status];
---

<article
  class="event-card"
  data-event-card
  data-city={data.venue.city}
  data-formats={data.formats?.join(" ") ?? ""}
  data-price-category={priceCategory}
  aria-labelledby={`event-${event.id}`}
>
  <div
    class="event-card__date"
    aria-label={`${copy.dateAria} ${formatEventDate(data.startAt, locale)}`}
  >
    <span>{formatEventDate(data.startAt, locale).split(" ")[0]}</span>
    <strong
      >{
        new Intl.DateTimeFormat(intlLocale[locale], {
          day: "numeric",
          timeZone: "Europe/Helsinki",
        }).format(new Date(data.startAt))
      }</strong
    >
    <small
      >{
        new Intl.DateTimeFormat(intlLocale[locale], {
          month: "short",
          timeZone: "Europe/Helsinki",
        }).format(new Date(data.startAt))
      }</small
    >
  </div>

  <div class="event-card__content">
    <div class="event-card__labels" aria-label={copy.eventStyleLabel}>
      {
        formatStates.map(({ format, state }) => (
          <span
            class:list={["format-pill", `format-pill--${state}`]}
            aria-label={`${formatLabels[format]}: ${formatStateLabels[state]}`}
          >
            <span aria-hidden="true">{formatStateIcons[state]}</span>
            {formatLabels[format]}
          </span>
        ))
      }
      {
        data.formats === null && (
          <span class="format-unknown-note">{copy.unknownFormatNote}</span>
        )
      }
      {
        statusLabel && (
          <span class:list={["pill", "pill--warning"]}>{statusLabel}</span>
        )
      }
    </div>

    <h2 id={`event-${event.id}`}>{data.title}</h2>

    <dl class="event-facts">
      <div>
        <dt>{copy.time}</dt>
        <dd>
          {formatEventDate(data.startAt, locale)}, {
            formatEventTime(data.startAt, locale)
          }–{formatEventTime(data.endAt, locale)}
        </dd>
      </div>
      <div>
        <dt>{copy.venue}</dt>
        <dd>
          <strong>{data.venue.name}</strong><br />
          <a href={mapUrl} target="_blank" rel="noreferrer"
            >{address}<span class="sr-only"> ({copy.opensNewTab})</span></a
          >
        </dd>
      </div>
      <div>
        <dt>{copy.price}</dt>
        <dd>{priceNote}</dd>
      </div>
      <div>
        <dt>{copy.audience}</dt>
        <dd>
          {eventText.accessDescription}
          {
            data.access.registrationRequired && (
              <span class="registration-note">{copy.registrationRequired}</span>
            )
          }
        </dd>
      </div>
      <div class="event-facts__source">
        <dt>{copy.organizerPage}</dt>
        <dd>
          <a
            class="source-link"
            href={data.sourceUrl}
            target="_blank"
            rel="noreferrer"
          >
            {copy.organizerLink}
            <span aria-hidden="true">↗</span>
            <span class="sr-only"> ({copy.opensNewTab})</span>
          </a>
        </dd>
      </div>
      <div
        class:list={[
          "event-facts__exceptions",
          data.schedule.exceptionStatus === "confirmation_required" &&
            "event-facts__exceptions--attention",
        ]}
      >
        <dt>{copy.exceptions}</dt>
        <dd>{eventText.exceptionNote}</dd>
      </div>
    </dl>

    <div class="event-card__footer">
      <span>{copy.checked} {formatVerifiedDate(data.verifiedAt, locale)}</span>
    </div>
  </div>
</article>
