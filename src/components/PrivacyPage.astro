---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "./SiteFooter.astro";
import SiteHeader from "./SiteHeader.astro";
import type { Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isFinnish = locale === "fi";
const privacyPaths = { fi: "/tietosuoja/", en: "/en/privacy/" };
const title = isFinnish
  ? "Tietosuoja ja yhteystiedot — Open Mats"
  : "Privacy and contact details — Open Mats";
const description = isFinnish
  ? "Tietoa Open Mats Helsinki Region -palvelun ylläpitäjästä ja henkilötietojen käsittelystä."
  : "Information about the operator of Open Mats Helsinki Region and the processing of personal data.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={privacyPaths[locale]}
  alternatePaths={privacyPaths}
  skipHref="#privacy-content"
  skipLabel={isFinnish ? "Siirry sisältöön" : "Skip to content"}
>
  <SiteHeader locale={locale} languagePaths={privacyPaths} />

  <main class="legal-main" id="privacy-content">
    <section class="legal-hero" aria-labelledby="privacy-title">
      <p class="eyebrow">Open Mats · Helsinki Region</p>
      <h1 id="privacy-title">
        {
          isFinnish
            ? "Tietosuoja ja yhteystiedot"
            : "Privacy and contact details"
        }
      </h1>
      <p>
        {
          isFinnish
            ? "Open Mats Helsinki Region on yksityinen, ei-kaupallinen koontipalvelu. Sivusto on suunniteltu keräämään mahdollisimman vähän henkilötietoja."
            : "Open Mats Helsinki Region is a private, non-commercial listing service. The site is designed to collect as little personal data as possible."
        }
      </p>
      <p class="legal-updated">
        {isFinnish ? "Päivitetty 17.7.2026" : "Updated 17 July 2026"}
      </p>
    </section>

    {
      isFinnish ? (
        <div class="legal-content">
          <section aria-labelledby="controller-title">
            <h2 id="controller-title">1. Rekisterinpitäjä ja yhteydenotot</h2>
            <p>
              <strong>Savi Santeri Pauli Virolainen</strong>
              <br />
              Yksityishenkilö
              <br />
              Sähköposti:{" "}
              <a href="mailto:savi1993@gmail.com">savi1993@gmail.com</a>
            </p>
            <p>
              Lähetä henkilötietojasi koskevat pyynnöt tähän osoitteeseen. Open
              Mats ei ole yrityksen tai yhdistyksen toimintaa.
            </p>
          </section>

          <section aria-labelledby="processing-title">
            <h2 id="processing-title">2. Mitä tietoja käsitellään ja miksi?</h2>
            <h3>Sivuston käyttö</h3>
            <p>
              Sivusto toimitetaan Cloudflare Pages -palvelun kautta. Cloudflare
              käsittelee sivupyynnön yhteydessä teknisiä tietoja, kuten
              IP-osoitetta, pyynnön aikaa ja kohdetta, selaimen tai laitteen
              teknisiä tietoja sekä liikenteen reititys- ja turvallisuustietoja.
            </p>
            <p>
              Tietoja käsitellään sivuston toimittamiseen, suojaamiseen,
              väärinkäytösten torjumiseen ja teknisten virheiden selvittämiseen.
              Käsittely perustuu rekisterinpitäjän oikeutettuun etuun pitää
              palvelu saatavilla ja turvallisena (EU:n yleisen
              tietosuoja-asetuksen 6 artiklan 1 kohdan f alakohta). Open Mats ei
              ylläpidä erillistä kävijärekisteriä, muodosta kävijäprofiileja
              eikä käytä tietoja mainontaan.
            </p>

            <h3>Tapahtumia koskevat ilmoitukset</h3>
            <p>
              Virheestä tai puuttuvasta open matista ilmoitetaan julkisessa
              GitHub-repositoriossa. Jos teet ilmoituksen,
              GitHub-käyttäjänimesi, profiilitietosi, ilmoituksen sisältö,
              ajankohdat ja mahdollinen keskustelu voivat näkyä julkisesti.
            </p>
            <p>
              Open Mats käsittelee ilmoitusta tapahtumatietojen tarkistamiseksi,
              korjaamiseksi ja yhteydenpitoa varten. Käsittely perustuu
              oikeutettuun etuun ylläpitää täsmällistä ja luotettavaa
              tapahtumalistausta. Älä kirjoita ilmoitukseen omia tai muiden
              yksityisiä yhteystietoja tai muita tarpeettomia henkilötietoja.
            </p>
            <p>
              Ilmoituksen tekeminen on vapaaehtoista. Jos et anna tietoja,
              mahdollista virhettä ei voida selvittää tämän ilmoituskanavan
              kautta. Tietoja ei käytetä profilointiin tai automaattiseen
              päätöksentekoon.
            </p>
          </section>

          <section aria-labelledby="recipients-title">
            <h2 id="recipients-title">
              3. Palveluntarjoajat ja tietojen siirrot
            </h2>
            <ul>
              <li>
                <strong>Cloudflare, Inc.</strong> toimittaa ja suojaa sivuston.
                Lue lisää{" "}
                <a href="https://www.cloudflare.com/privacypolicy/">
                  Cloudflaren tietosuojakäytännöstä
                </a>
                .
              </li>
              <li>
                <strong>GitHub, Inc.</strong> ylläpitää julkista repositoriota
                ja ilmoituksia. GitHub käsittelee palvelunsa käyttäjätietoja
                myös oman tietosuojakäytäntönsä mukaisesti. Lue lisää{" "}
                <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement">
                  GitHubin tietosuojakäytännöstä
                </a>
                .
              </li>
            </ul>
            <p>
              Nämä yhdysvaltalaiset palveluntarjoajat voivat käsitellä tietoja
              Euroopan talousalueen ulkopuolella. Palveluntarjoajat kuvaavat
              käyttämänsä siirtoperusteet, kuten
              EU–Yhdysvallat-tietosuojakehyksen ja tarvittaessa EU:n
              vakiolausekkeet, yllä linkitetyissä tietosuojatiedoissaan. Tietoja
              ei myydä eikä luovuteta muille tahoille muutoin kuin palvelun
              toteuttamiseksi tai lakiin perustuvasta syystä.
            </p>
          </section>

          <section aria-labelledby="retention-title">
            <h2 id="retention-title">4. Tietojen säilytys</h2>
            <p>
              Cloudflare käsittelee teknisiä tietoja vain palvelun
              toimittamiseen ja suojaamiseen tarvittavan ajan omien
              säilytyskäytäntöjensä mukaisesti. Open Mats ei lataa tai säilytä
              niistä erillistä kopiota.
            </p>
            <p>
              GitHub-ilmoitus säilyy julkisena niin kauan kuin sitä tarvitaan
              asian selvittämiseen, tapahtumatietojen korjaamiseen tai muutoksen
              dokumentointiin. Suljetut ilmoitukset tarkistetaan vähintään
              kerran vuodessa. Tarpeettomat henkilötiedot poistetaan tai
              peitetään; henkilötietoja sisältämätön tekninen sisältö voidaan
              säilyttää projektin muutoshistoriana.
            </p>
          </section>

          <section aria-labelledby="cookies-title">
            <h2 id="cookies-title">5. Evästeet ja seuranta</h2>
            <p>
              Open Mats ei käytä eikä aseta evästeitä, eikä sivustolla ole
              analytiikkaa, mainontaa, markkinointiseurantaa tai selaimen
              paikalliseen tallennustilaan kirjoittavaa toimintoa. Nykyinen
              toteutus ei käytä myöskään evästeen asettavia
              Cloudflare-ominaisuuksia. Jos toimintatapaa joskus muutetaan,
              tietosuojatiedot ja mahdollinen suostumusratkaisu arvioidaan ennen
              muutoksen käyttöönottoa.
            </p>
          </section>

          <section aria-labelledby="rights-title">
            <h2 id="rights-title">6. Oikeutesi</h2>
            <p>
              Tilanteen mukaan sinulla on oikeus saada tietoa henkilötietojesi
              käsittelystä, tarkastaa ja oikaista tietosi, pyytää tietojen
              poistamista tai käsittelyn rajoittamista sekä vastustaa
              oikeutettuun etuun perustuvaa käsittelyä. Oikeuksia voidaan
              rajoittaa laissa säädetyillä perusteilla.
            </p>
            <p>
              Lähetä pyyntö osoitteeseen{" "}
              <a href="mailto:savi1993@gmail.com">savi1993@gmail.com</a>.
              Pyyntöön vastataan ilman aiheetonta viivytystä ja tavallisesti
              kuukauden kuluessa. Sinulla on myös oikeus tehdä valitus{" "}
              <a href="https://tietosuoja.fi/ilmoitus-tietosuojavaltuutetulle">
                tietosuojavaltuutetun toimistolle
              </a>
              .
            </p>
          </section>

          <section aria-labelledby="links-title">
            <h2 id="links-title">7. Ulkopuoliset linkit ja muutokset</h2>
            <p>
              Tapahtumakorttien järjestäjä- ja karttalinkit sekä GitHub-linkki
              johtavat ulkopuolisiin palveluihin. Kun avaat linkin, kyseinen
              palvelu käsittelee tietoja oman tietosuojakäytäntönsä mukaisesti.
            </p>
            <p>
              Tätä tietosuojailmoitusta päivitetään, jos sivuston toiminta,
              palveluntarjoajat tai henkilötietojen käsittely muuttuvat.
            </p>
          </section>
        </div>
      ) : (
        <div class="legal-content">
          <section aria-labelledby="controller-title">
            <h2 id="controller-title">1. Controller and contact details</h2>
            <p>
              <strong>Savi Santeri Pauli Virolainen</strong>
              <br />
              Private individual
              <br />
              Email: <a href="mailto:savi1993@gmail.com">savi1993@gmail.com</a>
            </p>
            <p>
              Send requests concerning your personal data to this address. Open
              Mats is not operated by a company or an association.
            </p>
          </section>

          <section aria-labelledby="processing-title">
            <h2 id="processing-title">2. What data is processed and why?</h2>
            <h3>Using the website</h3>
            <p>
              The site is delivered through Cloudflare Pages. When a page is
              requested, Cloudflare processes technical data such as the IP
              address, request time and destination, browser or device
              information, and traffic routing and security information.
            </p>
            <p>
              This data is processed to deliver and protect the site, prevent
              abuse, and investigate technical errors. The legal basis is the
              controller’s legitimate interest in keeping the service available
              and secure (Article 6(1)(f) of the EU General Data Protection
              Regulation). Open Mats does not maintain a separate visitor
              register, create visitor profiles, or use the data for
              advertising.
            </p>

            <h3>Event reports</h3>
            <p>
              Errors and missing open mats are reported in a public GitHub
              repository. If you submit a report, your GitHub username, profile
              details, report content, timestamps, and any discussion may be
              publicly visible.
            </p>
            <p>
              Open Mats processes the report to verify and correct event
              information and to communicate with you. The legal basis is the
              legitimate interest in maintaining an accurate and reliable event
              listing. Do not include your own or anyone else’s private contact
              details or other unnecessary personal data in a report.
            </p>
            <p>
              Submitting a report is voluntary. If you do not provide the
              information, a possible error cannot be investigated through this
              reporting channel. The data is not used for profiling or automated
              decision-making.
            </p>
          </section>

          <section aria-labelledby="recipients-title">
            <h2 id="recipients-title">
              3. Service providers and data transfers
            </h2>
            <ul>
              <li>
                <strong>Cloudflare, Inc.</strong> delivers and protects the
                site. Read the{" "}
                <a href="https://www.cloudflare.com/privacypolicy/">
                  Cloudflare Privacy Policy
                </a>
                .
              </li>
              <li>
                <strong>GitHub, Inc.</strong> hosts the public repository and
                reports. GitHub also processes user data under its own privacy
                statement. Read the{" "}
                <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement">
                  GitHub General Privacy Statement
                </a>
                .
              </li>
            </ul>
            <p>
              These US-based providers may process data outside the European
              Economic Area. The providers describe the transfer mechanisms they
              use, including the EU–US Data Privacy Framework and, where
              applicable, EU Standard Contractual Clauses, in the linked privacy
              information. Personal data is not sold or disclosed to other
              parties except to provide the service or when required by law.
            </p>
          </section>

          <section aria-labelledby="retention-title">
            <h2 id="retention-title">4. Retention</h2>
            <p>
              Cloudflare processes technical data only for as long as necessary
              to deliver and protect the service under its retention practices.
              Open Mats does not download or retain a separate copy of that
              data.
            </p>
            <p>
              A GitHub report remains public for as long as it is needed to
              investigate the matter, correct event information, or document the
              change. Closed reports are reviewed at least once a year.
              Unnecessary personal data is removed or redacted; technical
              content without personal data may be retained as project history.
            </p>
          </section>

          <section aria-labelledby="cookies-title">
            <h2 id="cookies-title">5. Cookies and tracking</h2>
            <p>
              Open Mats does not use or set cookies, and the site has no
              analytics, advertising, marketing tracking, or functionality that
              writes to browser local storage. The current implementation also
              does not use Cloudflare features that set cookies. If this
              approach ever changes, the privacy information and any consent
              mechanism will be assessed before the change is enabled.
            </p>
          </section>

          <section aria-labelledby="rights-title">
            <h2 id="rights-title">6. Your rights</h2>
            <p>
              Depending on the circumstances, you have the right to receive
              information about the processing of your personal data, access and
              correct your data, request erasure or restriction of processing,
              and object to processing based on legitimate interests. These
              rights may be limited on grounds set out in law.
            </p>
            <p>
              Send your request to{" "}
              <a href="mailto:savi1993@gmail.com">savi1993@gmail.com</a>.
              Requests are answered without undue delay and usually within one
              month. You also have the right to lodge a complaint with the{" "}
              <a href="https://tietosuoja.fi/en/notification-to-the-data-protection-ombudsman">
                Office of the Data Protection Ombudsman
              </a>
              .
            </p>
          </section>

          <section aria-labelledby="links-title">
            <h2 id="links-title">7. External links and changes</h2>
            <p>
              Organizer and map links on event cards, as well as the GitHub
              link, lead to external services. When you open a link, that
              service processes data under its own privacy practices.
            </p>
            <p>
              This privacy notice will be updated if the site’s operation,
              service providers, or processing of personal data changes.
            </p>
          </section>
        </div>
      )
    }
  </main>

  <SiteFooter locale={locale} />
</BaseLayout>
