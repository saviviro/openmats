<section class="filters" aria-labelledby="filter-title">
  <div class="filters__heading">
    <div>
      <p class="eyebrow">Rajaa listaa</p>
      <h2 id="filter-title">Löydä sopiva open mat</h2>
    </div>
  </div>

  <div class="filter-groups">
    <fieldset data-filter-group="city">
      <legend>Kaupunki</legend>
      <div class="filter-buttons">
        <button type="button" data-filter-value="all" aria-pressed="true"
          >Kaikki</button
        >
        <button type="button" data-filter-value="Helsinki" aria-pressed="false"
          >Helsinki</button
        >
        <button type="button" data-filter-value="Espoo" aria-pressed="false"
          >Espoo</button
        >
        <button type="button" data-filter-value="Vantaa" aria-pressed="false"
          >Vantaa</button
        >
      </div>
    </fieldset>

    <fieldset data-filter-group="format">
      <legend>Tyyli</legend>
      <div class="filter-buttons">
        <button type="button" data-filter-value="all" aria-pressed="true"
          >Kaikki</button
        >
        <button type="button" data-filter-value="gi" aria-pressed="false"
          >Gi</button
        >
        <button type="button" data-filter-value="no-gi" aria-pressed="false"
          >No-gi</button
        >
      </div>
    </fieldset>
  </div>
</section>
